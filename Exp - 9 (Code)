import numpy as np
import matplotlib.pyplot as plt

from sklearn.linear_model import LinearRegression
from sklearn.preprocessing import PolynomialFeatures
from sklearn.metrics import mean_squared_error

# Sample dataset
X = np.array([[1],[2],[3],[4],[5],[6]])
y = np.array([1,4,9,16,25,36])

# -------- Linear Regression --------
linear_model = LinearRegression()
linear_model.fit(X, y)
y_pred_linear = linear_model.predict(X)

# -------- Polynomial Regression --------
poly = PolynomialFeatures(degree=2)
X_poly = poly.fit_transform(X)

poly_model = LinearRegression()
poly_model.fit(X_poly, y)
y_pred_poly = poly_model.predict(X_poly)

# -------- Error comparison --------
linear_error = mean_squared_error(y, y_pred_linear)
poly_error = mean_squared_error(y, y_pred_poly)

print("Linear Regression Error:", linear_error)
print("Polynomial Regression Error:", poly_error)

# -------- Plot results --------
plt.scatter(X, y, color='blue', label="Actual Data")
plt.plot(X, y_pred_linear, color='red', label="Linear Regression")
plt.plot(X, y_pred_poly, color='green', label="Polynomial Regression")
plt.legend()
plt.title("Linear vs Polynomial Regression")
plt.show()
